# Database (local dev)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/crm

# Docker Compose postgres service credentials
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm
POSTGRES_DB=crm

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret

# Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_ENCRYPTION_KEY=change-me-to-a-fernet-key

# Test database (optional — defaults to DATABASE_URL if not set)
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/crm_test

# CORS (comma-separated origins for production)
CORS_ORIGINS=["http://localhost:5173"]
